    {"name": "DS_STRATUM_WORKFLOW",   "label": "Stratum Workflow",   "type": "datasource", "pluginId": "grafana-postgresql-datasource"},
    {"name": "DS_STRATUM_INGESTION",  "label": "Stratum Ingestion",  "type": "datasource", "pluginId": "grafana-postgresql-datasource"}
  ]
