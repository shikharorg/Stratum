{
  "dashboard": {
    "uid": "82dbb5ca-e5a2-44f2-889f-3ebd76aa99c3",
    "title": "Stratum Platform Overview",
    "schemaVersion": 39,
    "tags": ["stratum"],
    "time": {"from": "now-7d", "to": "now"},
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Documents Ingested",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "cfou96fhd7w8wf"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "cfou96fhd7w8wf"}, "rawSql": "SELECT COUNT(*) FROM documents WHERE status='completed'", "format": "table", "refId": "A"}]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Total Searches",
        "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "ffou95zbsuy2of"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "ffou95zbsuy2of"}, "rawSql": "SELECT COUNT(*) FROM retrieval_logs", "format": "table", "refId": "A"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Total Workflow Runs",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "bfou96zjtcohsd"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "bfou96zjtcohsd"}, "rawSql": "SELECT COUNT(*) FROM workflow_runs", "format": "table", "refId": "A"}]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Avg RAG Score",
        "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"},
        "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.9}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"}, "rawSql": "SELECT ROUND(AVG(overall_score)::numeric, 2) FROM evaluation_results WHERE status='completed'", "format": "table", "refId": "A"}]
      },
      {
        "id": 5,
        "type": "gauge",
        "title": "Avg Faithfulness",
        "gridPos": {"x": 0, "y": 4, "w": 8, "h": 6},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "minVizWidth": 75, "minVizHeight": 75},
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.9}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"}, "rawSql": "SELECT AVG(faithfulness) FROM evaluation_results WHERE status='completed' AND faithfulness IS NOT NULL", "format": "table", "refId": "A"}]
      },
      {
        "id": 6,
        "type": "gauge",
        "title": "Avg Answer Relevancy",
        "gridPos": {"x": 8, "y": 4, "w": 8, "h": 6},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "minVizWidth": 75, "minVizHeight": 75},
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.9}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"}, "rawSql": "SELECT AVG(answer_relevancy) FROM evaluation_results WHERE status='completed' AND answer_relevancy IS NOT NULL", "format": "table", "refId": "A"}]
      },
      {
        "id": 7,
        "type": "gauge",
        "title": "Avg Context Precision",
        "gridPos": {"x": 16, "y": 4, "w": 8, "h": 6},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"},
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "minVizWidth": 75, "minVizHeight": 75},
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "green", "value": 0.9}]}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"}, "rawSql": "SELECT AVG(context_precision) FROM evaluation_results WHERE status='completed' AND context_precision IS NOT NULL", "format": "table", "refId": "A"}]
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "RAG Score Over Time",
        "gridPos": {"x": 0, "y": 10, "w": 12, "h": 8},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"},
        "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
        "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "palette-classic"}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "efou95471x0xsc"}, "rawSql": "SELECT created_at as time, overall_score FROM evaluation_results WHERE status='completed' ORDER BY created_at", "format": "time_series", "refId": "A"}]
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Search Latency (ms)",
        "gridPos": {"x": 12, "y": 10, "w": 12, "h": 8},
        "datasource": {"type": "grafana-postgresql-datasource", "uid": "ffou95zbsuy2of"},
        "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
        "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "palette-classic"}}},
        "targets": [{"datasource": {"type": "grafana-postgresql-datasource", "uid": "ffou95zbsuy2of"}, "rawSql": "SELECT created_at as time, latency_ms FROM retrieval_logs ORDER BY created_at", "format": "time_series", "refId": "A"}]
      }
    ]
  },
  "overwrite": true,
  "__inputs": [
